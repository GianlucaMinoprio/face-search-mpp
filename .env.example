# FaceCheck.id API token (get from https://facecheck.id/en/Face-Search/API)
FACECHECK_API_TOKEN=

# Your EVM wallet address to receive payments (Base + Tempo)
EVM_ADDRESS=

# MPP secret key for Tempo payment challenges (generate with: openssl rand -hex 32)
MPP_SECRET_KEY=

# x402 facilitator URL
FACILITATOR_URL=https://facilitator.payai.network

# Server port
PORT=4021

# Public base URL (for OpenAPI spec)
BASE_URL=http://localhost:4021
